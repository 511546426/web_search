# DeepSeek API (兼容 Anthropic 协议)
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash

# Seedance 2.0 (火山引擎)
SEEDANCE_API_KEY=your-seedance-api-key
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MODEL=doubao-seedance-2-0-260128

# 每日生成配额上限 (次)
DAILY_GENERATION_LIMIT=5

# SMB 远程存储 — 视频直接写入 Windows 共享，不占 VM 磁盘
SMB_HOST=192.168.1.6
SMB_SHARE=share
SMB_USER=Administrator
SMB_PASSWORD=your-windows-password
SMB_ROOT_DIR=comic_videos

# 视频输出目录（SMB 模式下不生效，文件直接写入 SMB 共享）
VIDEO_OUTPUT_DIR=

# B站开放平台 — 自动发布视频 (https://openhome.bilibili.com)
BILIBILI_APP_KEY=
BILIBILI_APP_SECRET=
BILIBILI_REFRESH_TOKEN=

# 服务器公网地址，供 Coze 回调获取视频（例如 https://your-domain.com）
PUBLIC_URL=https://your-domain.com
